# DorkMaster -- Environment Configuration
# Copy to .env and fill in your values.

# Serper.dev API keys (comma-separated, optional)
# SERPER_API_KEYS=key1,key2,key3

# Dork queries file
QUERIES_FILE=dorks.txt

# Free search engines (comma-separated)
# FREE_SEARCH_ENGINES=duckduckgo,bing

# Scanner settings (optional)
# SCAN_MAX_CONCURRENCY=20
# SCAN_TIMEOUT=10
# SCAN_RATE_LIMIT_RPS=50
